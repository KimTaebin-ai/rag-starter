# ── Required ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ── Model ───────────────────────────────────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-6
# MAX_TOKENS=1024

# ── Phase 0 — measurement (default ON) ──────────────────────────
# TRACK_TOKENS=1        # log + return input/output token counts
# DEBUG_SEARCH=1        # log retrieved chunks (query, score, source, chunk#)

# ── Retrieval ───────────────────────────────────────────────────
# TOP_K=5

# ── Phase 2-1 — similarity threshold filter (default ON) ────────
# ENABLE_THRESHOLD=1
# SIMILARITY_THRESHOLD=0.35   # cosine sim; below this a chunk is dropped

# ── Phase 2-2 — query rewrite (default OFF; extra LLM call) ─────
# ENABLE_QUERY_REWRITE=1

# ── Phase 3 — context assembly (default ON) ─────────────────────
# ENABLE_CHUNK_GROUPING=1       # 3-1: group chunks by document, in order
# ENABLE_SOURCE_IN_CONTEXT=1    # 3-2: prefix each chunk with its source

# ── Phase 4-1 — re-ranking (default OFF; extra LLM call) ────────
# ENABLE_RERANK=1
# RERANK_FETCH_K=30
# RERANK_TOP_N=5

# ── Phase 4-2 — agentic iterative search (default OFF; costly) ──
# ENABLE_AGENTIC_SEARCH=1
# MAX_SEARCH_ITERS=3
